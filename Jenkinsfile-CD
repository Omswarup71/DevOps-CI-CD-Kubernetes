pipeline {
agent any

```
environment {
    NODE_IP = "NODE_PRIVATE_IP_HERE"
    EC2_NAME = "ec2-user"
    PROJECT_NAME = "DevopsProject1"
}

stages {

    stage("1. Copy K8s Files To Node Server") {
        steps {
            sshagent(['my_ec2_creds']) {

                sh """
                scp -o StrictHostKeyChecking=no ${PROJECT_NAME}/deployment.yaml ${EC2_NAME}@${NODE_IP}:/home/ec2-user/
                """

                sh """
                scp -o StrictHostKeyChecking=no ${PROJECT_NAME}/service.yaml ${EC2_NAME}@${NODE_IP}:/home/ec2-user/
                """
            }
        }
    }

    stage("2. Manual Approval") {
        steps {
            input message: "Approve Kubernetes Deployment?"
        }
    }

    stage("3. Deploy To Kubernetes Node") {
        steps {
            sshagent(['my_ec2_creds']) {

                sh """
                ssh -o StrictHostKeyChecking=no ${EC2_NAME}@${NODE_IP} '
                kubectl apply -f deployment.yaml
                kubectl apply -f service.yaml
                kubectl rollout restart deployment devops-app
                kubectl get pods
                kubectl get svc
                '
                """
            }
        }
    }

}
```

